#version 460
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_debug_printf : enable
#define NB_PRIMITIVE_TYPES 6
#define MAX_FRAMES_IN_FLIGHT 2
#define MAX_BONES_INFLUENCE 4
layout (local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

// Déclaration du type de primitive + limites
layout (triangles, max_vertices = 255, max_primitives = 85) out;
layout(location = 0) out vec4 fragColor[];
layout(location = 1) out vec2 fragTexCoord[];
layout(location = 2) out vec3 normal[];
layout(location = 3) flat out int materialID[];
layout(location = 4) flat out int primitiveType[];
layout(location = 5) flat out int currentFrame[];
struct MeshDrawCommand {
    uint groupXCount;
    uint groupYCount;
    uint groupZCount;
};
struct LODLevel {
    uint index_offset;
    uint index_count;
    int meshletOffset;
    int meshletCount;
};
struct TaskData {
    MeshDrawCommand meshDrawCommand;
    uint baseInstance;
};
struct AABB {
	vec3 center;
	vec3 size;
};
struct MeshLet {
    uint vertexOffset;
    uint indexOffset;
    uint nbVertices;
    uint nbIndexes;
    uint minVertex;
    uint maxVertex;
};
struct SubMesh {
	AABB globalBounds;
	int vertexOffset;
	int indexOffset;
	int primitiveType;
	int materialId;
	int nbVertices;
	int nbIndexes;
	int lodOffset;
	int id;
    int lodLevel;
    int objectId;
    int meshletOffset;
    int meshletCount;
};
struct Vertex {
    vec3 position; ///< 3D position of the vertex
    uint color; ///< Color of the vertex
    vec2 texCoords; ///< Coordinates of the texture's pixel to map to the vertex
    vec3 normal;
    //bone indexes which will influence this vertex
    int m_BoneIDs[MAX_BONES_INFLUENCE];
    //weights from each bone
    float m_Weights[MAX_BONES_INFLUENCE];
    int submeshId;
};
struct ModelData {
    mat4 modelMatrix;
    mat4 shadowProjMatrix;
    mat4 borderMatrices;
};
struct LodLevel {
    uint index_offset;
    uint nbLevels;
};
struct TaskPayload {
    int taskId;
};
taskPayloadSharedEXT TaskPayload payload;
layout (push_constant) uniform PushConstant {
    mat4 projMatrix;
    mat4 viewMatrix;
    int primitiveType;
    int currentFrame;
} pc;
layout (std430, set = 0, binding = 0) buffer TastDataSSBO {
    TaskData taskData[];
} taskDatas[NB_PRIMITIVE_TYPES * MAX_FRAMES_IN_FLIGHT];
layout(std430, set = 0, binding = 1) buffer TaskCountSSBO {
    uint taskCount;
} TaskCounts[NB_PRIMITIVE_TYPES*MAX_FRAMES_IN_FLIGHT];
layout (std430, set = 0, binding = 2) buffer SubMeshDataSSBO {
    SubMesh subMeshData[];
} SubMeshDatas[NB_PRIMITIVE_TYPES * MAX_FRAMES_IN_FLIGHT];
layout (std430, set = 0, binding = 3) buffer ModelDataSSBO {
    ModelData modelData[];
} modelDataBuffer[NB_PRIMITIVE_TYPES * MAX_FRAMES_IN_FLIGHT];

layout (std430, set = 0, binding = 4) buffer vertexBufferSSBO {
    Vertex vertices[];
} vertexData[NB_PRIMITIVE_TYPES];
layout (std430, set = 0, binding = 5) buffer indexBufferSSBO {
    uint indexes[];
} indexData[NB_PRIMITIVE_TYPES];
layout (std430, set=0, binding = 6) buffer LodLevelBuffer {
    LODLevel lodLevel[];
} lodLevelData;
layout (std430, set = 0, binding = 7) buffer MeshletsSSBO {
    MeshLet meshlet[];
} meshletDatas;
vec4 unpackColor(uint c)
{
    float r = float((c >> 24) & 0xFFu) / 255.0;
    float g = float((c >> 16) & 0xFFu) / 255.0;
    float b = float((c >>  8) & 0xFFu) / 255.0;
    float a = float((c      ) & 0xFFu) / 255.0;

    return vec4(r, g, b, a);
}
void main() {      
    //Instance id = taskId (base instance) + workGroupId.x (instance id).
    uint instanceId = taskDatas[pc.primitiveType*MAX_FRAMES_IN_FLIGHT+pc.currentFrame].taskData[payload.taskId].baseInstance + gl_WorkGroupID.x;
    //debugPrintfEXT("Instance id : %i", gl_WorkGroupID.x); 
    mat4 modelMatrix = modelDataBuffer[pc.primitiveType*MAX_FRAMES_IN_FLIGHT+pc.currentFrame].modelData[instanceId].modelMatrix;
    SubMesh subMesh = SubMeshDatas[pc.primitiveType*MAX_FRAMES_IN_FLIGHT+pc.currentFrame].subMeshData[payload.taskId];
    //debugPrintfEXT("meshlet offets : %i, %i, %i", subMesh.meshletOffset,lodLevelData.lodLevel[subMesh.lodOffset+subMesh.lodLevel].meshletOffset, gl_WorkGroupID.y);
    MeshLet meshlet = meshletDatas.meshlet[subMesh.meshletOffset+lodLevelData.lodLevel[subMesh.lodOffset+subMesh.lodLevel].meshletOffset+gl_WorkGroupID.y];
    uint firstIndex = subMesh.indexOffset + lodLevelData.lodLevel[subMesh.lodOffset+subMesh.lodLevel].index_offset + meshlet.indexOffset;
    //debugPrintfEXT("First index : %i", firstIndex);
    //3 = Triangles.
    uint maxVerts = 255u;
    uint maxPrims = 85u;
    uint vertexCount   = min(meshlet.nbVertices, maxVerts);
    uint primitiveCount = min(meshlet.nbIndexes / 3u, maxPrims);
    /*if (vertexCount > 0)
        debugPrintfEXT("submesh vertex count : %i, %i", meshlet.nbVertices, meshlet.nbIndexes);*/
    //if (pc.primitiveType == 3) {       
        SetMeshOutputsEXT(vertexCount, primitiveCount);
        for (uint i = 0; i < vertexCount; i++) {
            uint v = subMesh.vertexOffset + meshlet.vertexOffset + i;
            gl_MeshVerticesEXT[i].gl_Position = pc.projMatrix * pc.viewMatrix * modelMatrix * vec4(vertexData[pc.primitiveType].vertices[v].position, 1.0);
            fragColor[i] = unpackColor(vertexData[pc.primitiveType].vertices[v].color);
            fragTexCoord[i] = vertexData[pc.primitiveType].vertices[v].texCoords;
            normal[i] = mat3(transpose(inverse(modelMatrix))) * vertexData[pc.primitiveType].vertices[v].normal;
            materialID[i] = subMesh.materialId;
            primitiveType[i] = pc.primitiveType;
            currentFrame[i] = pc.currentFrame;
            //debugPrintfEXT("position : %i",  i);
        }
        for (uint tri = 0; tri < primitiveCount; tri++) {
            //debugPrintfEXT("gen tri : %i", tri);
            uint i0 = indexData[pc.primitiveType].indexes[firstIndex + tri * 3 + 0] - meshlet.vertexOffset;
            uint i1 = indexData[pc.primitiveType].indexes[firstIndex + tri * 3 + 1] - meshlet.vertexOffset;
            uint i2 = indexData[pc.primitiveType].indexes[firstIndex + tri * 3 + 2] - meshlet.vertexOffset;   
            if (i0 >= vertexCount || i1 >= vertexCount || i2 >= vertexCount)
                debugPrintfEXT("triangle indexes : %i, %i, %i, %i, %i", i0, i1, i2, meshlet.vertexOffset, meshlet.nbVertices);   
            gl_PrimitiveTriangleIndicesEXT[tri] = uvec3(i0, i1, i2);            
        }
    //}
}