# Order-only phony target for odfaeg-graphics

build cmake_object_order_depends_target_odfaeg-graphics: phony || cmake_object_order_depends_target_meshoptimizer cmake_object_order_depends_target_odfaeg-core-mod cmake_object_order_depends_target_odfaeg-entity-mod cmake_object_order_depends_target_odfaeg-graphics-mod cmake_object_order_depends_target_odfaeg-math-mod cmake_object_order_depends_target_odfaeg-physics-mod cmake_object_order_depends_target_odfaeg-window-mod


# =============================================================================
# Link build statements for STATIC_LIBRARY target odfaeg-graphics


#############################################
# Link the static library src/odfaeg/Graphics/libodfaeg-graphics.a

build src/odfaeg/Graphics/libodfaeg-graphics.a: CXX_STATIC_LIBRARY_LINKER__odfaeg-graphics_Release || src/odfaeg/Core/libodfaeg-core-mod.a src/odfaeg/Entity/libodfaeg-entity-mod.a src/odfaeg/Graphics/libmeshoptimizer.a src/odfaeg/Graphics/libodfaeg-graphics-mod.a src/odfaeg/Math/libodfaeg-math-mod.a src/odfaeg/Physics/libodfaeg-physics-mod.a src/odfaeg/Window/libodfaeg-window-mod.a
  LANGUAGE_COMPILE_FLAGS = -stdlib=libstdc++ -O3 -DNDEBUG
  OBJECT_DIR = src/odfaeg/Graphics/CMakeFiles/odfaeg-graphics.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_FILE = src/odfaeg/Graphics/libodfaeg-graphics.a
  TARGET_PDB = odfaeg-graphics.a.dbg


#############################################
# Utility command for edit_cache

build src/odfaeg/Graphics/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/laurent/ODFAEG-master/ODFAEG2/build/src/odfaeg/Graphics && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build src/odfaeg/Graphics/edit_cache: phony src/odfaeg/Graphics/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build src/odfaeg/Graphics/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/laurent/ODFAEG-master/ODFAEG2/build/src/odfaeg/Graphics && /usr/bin/cmake --regenerate-during-build -S/home/laurent/ODFAEG-master/ODFAEG2 -B/home/laurent/ODFAEG-master/ODFAEG2/build
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build src/odfaeg/Graphics/rebuild_cache: phony src/odfaeg/Graphics/CMakeFiles/rebuild_cache.util


#############################################
