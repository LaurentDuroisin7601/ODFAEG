{
	"version": 5,	
	"configurePresets": [
		{
			"name": "windows-msvc",
			"generator": "Ninja",
			"binaryDir": "out/build/debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
				"CMAKE_C_COMPILER": "cl",
				"CMAKE_CXX_COMPILER": "cl"
			}
		},
		{
			"name": "msys2-clang",
			"generator": "Ninja",
			"binaryDir": "out/build/release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_C_COMPILER": "C:/msys64/mingw64/bin/clang.exe",
				"CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/clang++.exe",
				"CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "C:/Program Files/LLVM/bin/clang-scan-deps.exe",
				"CMAKE_TOOLCHAIN_FILE": "cmake/toolchains/msys2-clang.cmake"
			}
		},
		{
			"name": "linux-conan",
			"displayName": "Linux (GCC/Clang + Conan)",
			"generator": "Ninja",
			"binaryDir": "out/build/linux",
			"cacheVariables": {
				"CMAKE_TOOLCHAIN_FILE": "${sourceDir}out/build/conan_toolchain.cmake"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		}
	]
}